// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  admin
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  passwordHash String?
  role         Role     @default(user)

  savedProjects       SavedProject[]
  shoppingListChecks  ShoppingListCheck[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model SavedProject {
  id       String @id @default(cuid())
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  moduleId String

  name            String
  // Respuestas del wizard y resultado calculado, guardados como snapshot —
  // el detalle del proyecto no recalcula contra el módulo actual.
  answers         Json
  result          Json
  progressPercent Int    @default(0)
  // Incluido en /lista-compras (consolidación de materiales entre proyectos).
  inShoppingList  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([moduleId])
  @@map("saved_projects")
}

// Estado de "comprado" por línea consolidada de la lista de compras.
// La identidad de una línea es (materialName, unit) tal como aparece en el
// snapshot de CalculationResult — no un Material.id, porque el nombre puede
// venir de un materialLabelTemplate dinámico sin fila de Material fija.
model ShoppingListCheck {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  materialName String
  unit         String
  checked      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, materialName, unit])
  @@index([userId])
  @@map("shopping_list_checks")
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  tag         String?
  order       Int      @default(0)
  modules     Module[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categories")
}

model Module {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  // Texto libre opcional para mejorar el buscador de la Home sin depender
  // solo del nombre/descripción exactos (ej. "radier patio piso hormigón").
  searchKeywords String?
  version     Int      @default(1)
  published   Boolean  @default(false)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId  String

  questions     Question[]
  variables     Variable[]
  formulas      Formula[]
  lossFactors   LossFactor[]
  savedProjects SavedProject[]
  projectTaskLinks ProjectTaskModule[]
  // Contenido "resultado enriquecido" opcional (piloto, ver ModuleGuide) —
  // hoy solo existe para Radier, no se genera en vivo por IA.
  guide         ModuleGuide?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@map("modules")
}

// Contenido editorial estático que acompaña el resultado de un módulo
// (piloto de "resultado enriquecido"): consejos prácticos redactados a
// mano, no generados en vivo por IA. Relación 1:1 opcional — la mayoría de
// los módulos no la tienen. `faqs` es un array JSON de {question, answer}.
model ModuleGuide {
  id       String @id @default(cuid())
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId String @unique

  summary                String
  tools                  String[]
  estimatedTime          String
  difficulty             String
  recommendedPeople      String
  tipsBeforeStart        String[]
  commonMistakes         String[]
  safetyRecommendations  String[]
  bestPractice           String
  masterTip              String
  faqs                   Json
  stepByStepSummary      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("module_guides")
}

enum QuestionType {
  NUMBER
  SELECT
  TEXT
}

model Question {
  id       String       @id @default(cuid())
  module   Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId String
  key      String
  label    String
  type     QuestionType
  unit     String?
  helpText String?
  order    Int          @default(0)
  // Preguntas del mismo módulo que comparten este valor se renderizan juntas
  // en un solo paso del wizard (ver docs/formula-dsl.md).
  stepGroup String?
  // Visibilidad condicional: si están seteados, esta pregunta solo se
  // muestra (y se pide) cuando la respuesta a la pregunta
  // visibleIfQuestionKey esté dentro de visibleIfValues. Sin admin UI
  // todavía — se configura por script (ver docs/formula-dsl.md).
  visibleIfQuestionKey String?
  visibleIfValues      String[] @default([])

  // Valor sugerido (editable) para precargar el campo NUMBER, calculado por
  // LOOKUP contra la respuesta de otra pregunta ya contestada — ej. sugerir
  // dimensiones típicas de fundación según el "uso" elegido. Sin admin UI
  // todavía — se configura por script. Forma: { type: "LOOKUP", questionKey,
  // table: { [answerKey]: number } }.
  defaultSource Json?

  options QuestionOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, key])
  @@index([moduleId])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String
  key        String
  label      String
  order      Int      @default(0)

  @@unique([questionId, key])
  @@map("question_options")
}

enum VariableValueType {
  NUMBER
  TEXT
}

// source: ver docs/formula-dsl.md
model Variable {
  id        String             @id @default(cuid())
  module    Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String
  key       String
  label     String             @default("")
  valueType VariableValueType
  source    Json
  // Si es true, el valor resuelto de esta variable se muestra en el resultado
  // (ej: "Tipo de hormigón: G20"), no solo las cantidades de las fórmulas.
  isResult  Boolean            @default(false)
  norm      Norm?              @relation(fields: [normId], references: [id], onDelete: SetNull)
  normId    String?
  order     Int                @default(0)

  @@unique([moduleId, key])
  @@index([moduleId])
  @@map("variables")
}

// Catálogo global de materiales, reutilizable entre módulos.
model Material {
  id   String @id @default(cuid())
  key  String @unique
  name String
  unit String

  formulas Formula[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("materials")
}

// expression / condition: ver docs/formula-dsl.md
model Formula {
  id         String    @id @default(cuid())
  module     Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId   String
  key        String
  label      String
  unit       String
  expression Json
  condition  Json?
  isResult   Boolean   @default(true)
  // Resultado secundario/de referencia (ej. "equivale a X sacos") — se
  // renderiza más chico, anidado dentro de la tarjeta del resultado
  // principal inmediatamente anterior, no como su propia tarjeta.
  isSecondary Boolean  @default(false)
  note       String?
  material   Material? @relation(fields: [materialId], references: [id])
  materialId String?
  // Plantilla opcional para el nombre de material mostrado en el resultado,
  // con placeholders {variableKey} interpolados con los valores de variable
  // ya resueltos al momento del cálculo (ver docs/formula-dsl.md). Si está
  // presente, reemplaza a material.name — útil cuando el nombre depende de
  // varias variables de selección (medida, espesor, etc.) y crear un
  // Material por combinación sería inviable.
  materialLabelTemplate String?
  norm       Norm?     @relation(fields: [normId], references: [id], onDelete: SetNull)
  normId     String?
  order      Int       @default(0)

  @@unique([moduleId, key])
  @@index([moduleId])
  @@map("formulas")
}

// condition: ver docs/formula-dsl.md
model LossFactor {
  id         String  @id @default(cuid())
  module     Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId   String
  key        String
  label      String
  percentage Float
  condition  Json?
  norm       Norm?   @relation(fields: [normId], references: [id], onDelete: SetNull)
  normId     String?

  @@unique([moduleId, key])
  @@index([moduleId])
  @@map("loss_factors")
}

enum NormVerificationStatus {
  // El valor está citado con una fuente normativa/técnica identificada.
  CITADO
  // Es práctica de obra habitual; no se ha verificado contra una norma o
  // guía técnica específica todavía.
  PRACTICA_GENERAL_NO_VERIFICADA
}

// Catálogo de normas/fuentes técnicas citadas por variables, fórmulas o
// factores de pérdida. Ver docs/auditoria-normativa.md.
model Norm {
  id                 String                 @id @default(cuid())
  code               String                 @unique
  title              String
  year               Int?
  scope              String
  verificationStatus NormVerificationStatus
  note               String?
  // Marca normas cuya nota exige explícitamente el criterio de un
  // profesional habilitado (elemento estructural o instalación regulada:
  // Vigas, Losas, Fierros, Gas, etc.) — usado para agregar una advertencia
  // reforzada al prompt de IA generado desde el resultado.
  reinforcedWarning Boolean @default(false)

  variables   Variable[]
  formulas    Formula[]
  lossFactors LossFactor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("norms")
}

// Fase 2 — capa de descubrimiento por proyecto sobre la Home, encima de
// Category/Module (que no se tocan). Ver docs/fase2-home-por-proyecto.md
// si se agrega más adelante.
model ProjectGroup {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  icon  String
  order Int    @default(0)
  // Tono especial de presentación (ej. "avanzado" para "Herramientas
  // avanzadas" — tratamiento visual más discreto en la Home).
  tone  String?

  tasks ProjectTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_groups")
}

model ProjectTask {
  id      String       @id @default(cuid())
  slug    String       @unique
  name    String
  order   Int          @default(0)
  group   ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String

  moduleLinks ProjectTaskModule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@map("project_tasks")
}

// Vincula una ProjectTask a uno o más Module existentes. Si una tarea
// tiene 2+ links, la página /empezar/[taskSlug] muestra un selector; si
// tiene 1 solo, redirige directo al módulo.
model ProjectTaskModule {
  id       String      @id @default(cuid())
  task     ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId   String
  module   Module      @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  moduleId String
  // Etiqueta para desambiguar cuando hay 2+ módulos (ej. "Rectangular").
  label    String?
  // Query string opcional a anexar al entrar al módulo (ej.
  // "tipo=bodega_industrial"), para preseleccionar la primera pregunta.
  presetQuery String?
  order    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([moduleId])
  @@map("project_task_modules")
}
