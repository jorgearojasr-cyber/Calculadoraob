// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  admin
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  passwordHash String?
  role         Role     @default(user)

  savedProjects SavedProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model SavedProject {
  id       String @id @default(cuid())
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  moduleId String

  name            String
  // Respuestas del wizard y resultado calculado, guardados como snapshot —
  // el detalle del proyecto no recalcula contra el módulo actual.
  answers         Json
  result          Json
  progressPercent Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([moduleId])
  @@map("saved_projects")
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  tag         String?
  order       Int      @default(0)
  modules     Module[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categories")
}

model Module {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  version     Int      @default(1)
  published   Boolean  @default(false)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId  String

  questions     Question[]
  variables     Variable[]
  formulas      Formula[]
  lossFactors   LossFactor[]
  savedProjects SavedProject[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@map("modules")
}

enum QuestionType {
  NUMBER
  SELECT
  TEXT
}

model Question {
  id       String       @id @default(cuid())
  module   Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId String
  key      String
  label    String
  type     QuestionType
  unit     String?
  helpText String?
  order    Int          @default(0)
  // Preguntas del mismo módulo que comparten este valor se renderizan juntas
  // en un solo paso del wizard (ver docs/formula-dsl.md).
  stepGroup String?
  // Visibilidad condicional: si están seteados, esta pregunta solo se
  // muestra (y se pide) cuando la respuesta a la pregunta
  // visibleIfQuestionKey esté dentro de visibleIfValues. Sin admin UI
  // todavía — se configura por script (ver docs/formula-dsl.md).
  visibleIfQuestionKey String?
  visibleIfValues      String[] @default([])

  options QuestionOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, key])
  @@index([moduleId])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String
  key        String
  label      String
  order      Int      @default(0)

  @@unique([questionId, key])
  @@map("question_options")
}

enum VariableValueType {
  NUMBER
  TEXT
}

// source: ver docs/formula-dsl.md
model Variable {
  id        String             @id @default(cuid())
  module    Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String
  key       String
  label     String             @default("")
  valueType VariableValueType
  source    Json
  // Si es true, el valor resuelto de esta variable se muestra en el resultado
  // (ej: "Tipo de hormigón: G20"), no solo las cantidades de las fórmulas.
  isResult  Boolean            @default(false)
  norm      Norm?              @relation(fields: [normId], references: [id], onDelete: SetNull)
  normId    String?
  order     Int                @default(0)

  @@unique([moduleId, key])
  @@index([moduleId])
  @@map("variables")
}

// Catálogo global de materiales, reutilizable entre módulos.
model Material {
  id   String @id @default(cuid())
  key  String @unique
  name String
  unit String

  formulas Formula[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("materials")
}

// expression / condition: ver docs/formula-dsl.md
model Formula {
  id         String    @id @default(cuid())
  module     Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId   String
  key        String
  label      String
  unit       String
  expression Json
  condition  Json?
  isResult   Boolean   @default(true)
  note       String?
  material   Material? @relation(fields: [materialId], references: [id])
  materialId String?
  // Plantilla opcional para el nombre de material mostrado en el resultado,
  // con placeholders {variableKey} interpolados con los valores de variable
  // ya resueltos al momento del cálculo (ver docs/formula-dsl.md). Si está
  // presente, reemplaza a material.name — útil cuando el nombre depende de
  // varias variables de selección (medida, espesor, etc.) y crear un
  // Material por combinación sería inviable.
  materialLabelTemplate String?
  norm       Norm?     @relation(fields: [normId], references: [id], onDelete: SetNull)
  normId     String?
  order      Int       @default(0)

  @@unique([moduleId, key])
  @@index([moduleId])
  @@map("formulas")
}

// condition: ver docs/formula-dsl.md
model LossFactor {
  id         String  @id @default(cuid())
  module     Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId   String
  key        String
  label      String
  percentage Float
  condition  Json?
  norm       Norm?   @relation(fields: [normId], references: [id], onDelete: SetNull)
  normId     String?

  @@unique([moduleId, key])
  @@index([moduleId])
  @@map("loss_factors")
}

enum NormVerificationStatus {
  // El valor está citado con una fuente normativa/técnica identificada.
  CITADO
  // Es práctica de obra habitual; no se ha verificado contra una norma o
  // guía técnica específica todavía.
  PRACTICA_GENERAL_NO_VERIFICADA
}

// Catálogo de normas/fuentes técnicas citadas por variables, fórmulas o
// factores de pérdida. Ver docs/auditoria-normativa.md.
model Norm {
  id                 String                 @id @default(cuid())
  code               String                 @unique
  title              String
  year               Int?
  scope              String
  verificationStatus NormVerificationStatus
  note               String?

  variables   Variable[]
  formulas    Formula[]
  lossFactors LossFactor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("norms")
}
